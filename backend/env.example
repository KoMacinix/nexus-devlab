# ─────────────────────────────────────────────────────────────────────────────
# NEXUS DevLab — Variables d'environnement backend
#
# En LOCAL  : copier ce fichier en .env et remplir les valeurs.
# Sur RENDER : ne rien committer — saisir ces variables dans
#              Dashboard → service backend → Environment.
# ─────────────────────────────────────────────────────────────────────────────

# Port d'écoute du serveur.
# - En local : 4000.
# - Sur Render : Render injecte automatiquement la variable PORT,
#   donc tu peux LAISSER cette ligne vide en prod (ou la supprimer).
PORT=4000

# MongoDB Atlas — quiz Tookah + comptes utilisateurs.
# Format Atlas : mongodb+srv://USER:PASS@CLUSTER.mongodb.net/nexus-devlab?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/nexus-devlab

# PostgreSQL Neon — StockOS, Forge, ShowPass.
# Format Neon : postgresql://USER:PASS@ep-xxxx.region.aws.neon.tech/nexus-devlab?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxxx.region.aws.neon.tech/nexus-devlab?sslmode=require

# Secret JWT — à régénérer pour la prod (ex: `openssl rand -hex 32`).
JWT_SECRET=nexus-devlab-super-secret-change-me

# Origine(s) autorisée(s) côté CORS / Socket.IO.
# Plusieurs URLs : séparer par des virgules, SANS slash final.
# Exemple typique :
#   - https://nexus-devlab.onrender.com    (frontend Render)
#   - https://www.tondomaine.com           (domaine OVH branché sur Render)
#   - https://tondomaine.com               (idem sans www)
# Les origines localhost (5173, 3000) sont toujours acceptées en plus.
FRONTEND_URL=https://nexus-devlab.onrender.com,https://www.tondomaine.com,https://tondomaine.com

# ─────────────────────────────────────────────────────────────────────────────
# FloraNet — Identifiants admin du dashboard (login dédié).
# Le login Floranet (POST /api/floranet/auth/login) est isolé du login Nexus :
# il utilise un JWT avec un `sub` (username), pas un `id` MongoDB.
# En prod, remplacer ABSOLUMENT par des valeurs robustes.
# ─────────────────────────────────────────────────────────────────────────────
FLORANET_ADMIN_USERNAME=admin
FLORANET_ADMIN_PASSWORD=change-me-floranet

# Durée de vie du JWT Floranet (en minutes). 1440 = 24h (défaut).
FLORANET_JWT_EXPIRE_MINUTES=1440
